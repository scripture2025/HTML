local char = player.Character or player.CharacterAdded:Wait()
local hum = char:WaitForChild("Humanoid")

local idleAnim = Instance.new("Animation")
idleAnim.AnimationId = "rbxassetid://136687532783709"

local walkAnim = Instance.new("Animation")
walkAnim.AnimationId = "rbxassetid://99498309796580"

local jumpAnim = Instance.new("Animation")
jumpAnim.AnimationId = "rbxassetid://139390570947836"

local idleTrack = hum:LoadAnimation(idleAnim)
local walkTrack = hum:LoadAnimation(walkAnim)
local jumpTrack = hum:LoadAnimation(jumpAnim)

local isEnabled = false
local connections = {}

local function play(anim)
    if not isEnabled then return end
    idleTrack:Stop()
    walkTrack:Stop()
    jumpTrack:Stop()
    anim:Play()
end

local function setupAnimations()
    for _, connection in pairs(connections) do
        connection:Disconnect()
    end
    connections = {}
    
    table.insert(connections, hum.Running:Connect(function(speed)
        if not isEnabled then return end
        if hum:GetState() == Enum.HumanoidStateType.Jumping or hum:GetState() == Enum.HumanoidStateType.Freefall then
            return
        end
        if speed > 0 then
            play(walkTrack)
        else
            play(idleTrack)
        end
    end))
    
    table.insert(connections, hum.Jumping:Connect(function()
        if not isEnabled then return end
        play(jumpTrack)
    end))
    
    table.insert(connections, hum.StateChanged:Connect(function(_, newState)
        if not isEnabled then return end
        if newState == Enum.HumanoidStateType.Landed then
            if hum.MoveDirection.Magnitude > 0 then
                play(walkTrack)
            else
                play(idleTrack)
            end
        end
    end))
end

local function toggleAnimations()
    isEnabled = not isEnabled
    
    if isEnabled then
        toggleButton.Text = "Aura Animation Pack: ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        setupAnimations()
        play(idleTrack)
    else
        toggleButton.Text = "Aura Animation Pack: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(55, 55, 75)
        idleTrack:Stop()
        walkTrack:Stop()
        jumpTrack:Stop()
        
        for _, connection in pairs(connections) do
            connection:Disconnect()
        end
        connections = {}
    end
end

toggleButton.MouseButton1Click:Connect(toggleAnimations)

player.CharacterAdded:Connect(function(newChar)
    char = newChar
    hum = char:WaitForChild("Humanoid")
    
    idleTrack = hum:LoadAnimation(idleAnim)
    walkTrack = hum:LoadAnimation(walkAnim)
    jumpTrack = hum:LoadAnimation(jumpAnim)
    
    if isEnabled then
        for _, connection in pairs(connections) do
            connection:Disconnect()
        end
        connections = {}
        setupAnimations()
        play(idleTrack)
    end
end)

play(idleTrack)
